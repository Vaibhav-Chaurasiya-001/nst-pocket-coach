# Copy to .env and fill in ONE of these.
# If neither is set, app uses Ollama at localhost:11434.

# OPTION A: Use Google AI Studio (free tier, no credit card)
# Get a key: https://aistudio.google.com/apikey
# Default model on this path: gemini-2.5-flash (Gemma 4 is not yet stable
# on Google AI Studio's free tier as of 2026-05). To switch when it
# becomes available:
#   GOOGLE_MODEL=gemma-4-26b-a4b-it
# GOOGLE_API_KEY=

# OPTION B: Use Ollama (local) — leave GOOGLE_API_KEY unset
# Default model: gemma4:e2b. Make sure Ollama is running and you've run
# `ollama pull gemma4:e2b` (~7GB).
# OLLAMA_MODEL=gemma4:e2b
